# Express server port
PORT=3000

# Set to 'production' to enable Secure cookies and serve the static React build
NODE_ENV=development

# SQLite database file path (relative to project root)
DB_PATH=./data/app.db

# File storage root — images and templates are stored here
UPLOAD_DIR=./uploads

# Font files directory (defaults to ./public/fonts)
FONTS_DIR=./public/fonts

# Allowed CORS origin for the Vite dev server (dev only, ignored in production)
CORS_ORIGIN=http://localhost:5173
