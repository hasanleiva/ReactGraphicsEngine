# Express server port (Nginx proxies to this)
PORT=3001

# SQLite database file path (relative to project root)
DB_PATH=./data/canva.db

# Base directory for file uploads (images, templates, fonts)
UPLOADS_PATH=./uploads

# Set to 'production' on VPS (enables secure cookies)
NODE_ENV=production

# Your domain URL - used for CORS origin check
# APP_URL=https://yourdomain.com
